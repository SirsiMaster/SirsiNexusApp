# ── SirsiNexusApp Monorepo npm Configuration ──
# Required for workspace peer dependency resolution between:
#   - sirsi-ui (React 18 peers from Storybook/component-library)
#   - sirsi-portal-app (React 19)
#   - sirsi-sign (React 19)
# Without this, npm install/ci fails with ERESOLVE peer conflicts.
legacy-peer-deps=true
